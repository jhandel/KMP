{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch KMP - Edge",
            "url": "http://localhost:8080"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch KMP - Chrome",
            "url": "http://localhost:8080"
        },
        {
            "name": "Listen for Xdebug (Docker app)",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "hostname": "0.0.0.0",
            "pathMappings": {
                "/var/www/html": "${workspaceFolder}/app"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch KMP - Chrome with Xdebug",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}/app/webroot"
        },
        {
            "name": "Launch currently open script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 0,
            "runtimeArgs": [
                "-dxdebug.start_with_request=yes"
            ],
            "env": {
                "XDEBUG_MODE": "debug,develop",
                "XDEBUG_CONFIG": "client_port=${port}"
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug KMP Docker app in Chrome",
            "configurations": [
                "Listen for Xdebug (Docker app)",
                "Launch KMP - Chrome with Xdebug"
            ],
            "stopAll": true
        }
    ]
}
