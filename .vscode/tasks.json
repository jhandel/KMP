{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Docker: Start KMP Dev Environment",
            "type": "shell",
            "command": "./dev-up.sh",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Rebuild KMP Dev Environment",
            "type": "shell",
            "command": "./dev-up.sh --build",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Stop KMP Dev Environment",
            "type": "shell",
            "command": "./dev-down.sh",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: PHPUnit",
            "type": "shell",
            "command": "./dev-test.sh php",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Jest",
            "type": "shell",
            "command": "./dev-test.sh js",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Vite Build",
            "type": "shell",
            "command": "./dev-test.sh build",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Playwright Smoke",
            "type": "shell",
            "command": "./dev-test.sh ui-smoke",
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Docker: Reset Database with Seed",
            "type": "shell",
            "command": "./dev-test.sh reset-db --seed",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Security Tests",
            "type": "shell",
            "command": "bash ${workspaceFolder}/security-checker.sh",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run All Tests",
            "type": "shell",
            "command": "npm run test",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run UI Tests",
            "type": "shell",
            "command": "npm run test:ui",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Run UI Tests (Headed)",
            "type": "shell",
            "command": "npm run test:ui:headed",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Debug UI Tests",
            "type": "shell",
            "command": "npm run test:ui:debug",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Generate UI Test Code",
            "type": "shell",
            "command": "npm run test:ui:codegen",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Show UI Test Report",
            "type": "shell",
            "command": "npx playwright show-report tests/ui-reports/html --port 9324",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Open UI Test Report in Browser",
            "type": "shell",
            "command": "code --open-url http://localhost:9324",
            "group": "test",
            "dependsOrder": "sequence",
            "dependsOn": "Show UI Test Report",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        },
        {
            "label": "Run PHPUnit Tests",
            "type": "shell",
            "command": "vendor/bin/phpunit",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Playwright Browsers",
            "type": "shell",
            "command": "npm run test:ui:install",
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "View UI Test Report",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Start UI Test Report Server",
                "Open Report in Simple Browser"
            ],
            "group": "test",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Start UI Test Report Server",
            "type": "shell",
            "command": "npx playwright show-report tests/ui-reports/html --port 9324 --host 0.0.0.0",
            "group": "test",
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": [],
            "isBackground": true,
            "runOptions": {
                "instanceLimit": 1
            }
        },
        {
            "label": "Open Report in Simple Browser",
            "type": "shell",
            "command": "sleep 2 && echo 'Opening report in Simple Browser...'",
            "group": "test",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": []
        }
    ]
}
