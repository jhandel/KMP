{
    "nodes": {
        "trigger": {
            "type": "trigger",
            "label": "Recommendation Transition Requested",
            "config": {
                "event": "Awards.RecommendationTransitionRequested",
                "entityIdField": "recommendationId"
            },
            "position": {
                "x": 50,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "transition-recommendation"
                }
            ]
        },
        "transition-recommendation": {
            "type": "action",
            "label": "Transition Recommendation",
            "config": {
                "action": "Awards.TransitionState",
                "params": {
                    "recommendationId": "$.trigger.recommendationId",
                    "targetState": "$.trigger.targetState",
                    "data": "$.trigger.data",
                    "actorId": "$.trigger.actorId"
                }
            },
            "position": {
                "x": 350,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "transition-succeeded"
                }
            ]
        },
        "transition-succeeded": {
            "type": "condition",
            "label": "Transition Succeeded?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.nodes.transition-recommendation.result.success",
                "value": true
            },
            "position": {
                "x": 650,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "end-success",
                    "label": "Transitioned"
                },
                {
                    "port": "false",
                    "target": "end-failed",
                    "label": "Failed"
                }
            ]
        },
        "end-success": {
            "type": "end",
            "label": "Transition Complete",
            "config": {
                "result": "$.nodes.transition-recommendation.result"
            },
            "position": {
                "x": 950,
                "y": 225
            },
            "outputs": []
        },
        "end-failed": {
            "type": "end",
            "label": "Transition Failed",
            "config": {
                "result": "$.nodes.transition-recommendation.result"
            },
            "position": {
                "x": 950,
                "y": 375
            },
            "outputs": []
        }
    },
    "startNode": "trigger"
}
