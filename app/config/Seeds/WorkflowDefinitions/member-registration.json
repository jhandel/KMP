{
    "nodes": {
        "trigger-registration": {
            "type": "trigger",
            "label": "Member Registered",
            "config": {
                "event": "Members.Registered",
                "entityIdField": "memberId"
            },
            "position": {
                "x": 50,
                "y": 200
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "assign-status-and-tokens"
                }
            ]
        },
        "assign-status-and-tokens": {
            "type": "action",
            "label": "Assign Status and Tokens",
            "config": {
                "action": "Members.AssignStatusAndTokens",
                "params": {
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": {
                "x": 350,
                "y": 200
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "check-is-minor"
                }
            ]
        },
        "check-is-minor": {
            "type": "condition",
            "label": "Is Minor?",
            "config": {
                "condition": "Members.IsMinor",
                "memberId": "$.trigger.memberId"
            },
            "position": {
                "x": 650,
                "y": 200
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "notify-secretary-minor",
                    "label": "Minor"
                },
                {
                    "port": "false",
                    "target": "send-registration-email",
                    "label": "Adult"
                }
            ]
        },
        "send-registration-email": {
            "type": "action",
            "label": "Send Registration Email with Reset Link",
            "config": {
                "action": "Members.SendRegistrationEmail",
                "params": {
                    "memberId": "$.trigger.memberId",
                    "email": "$.trigger.email"
                }
            },
            "position": {
                "x": 950,
                "y": 300
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "notify-secretary-adult"
                }
            ]
        },
        "notify-secretary-adult": {
            "type": "action",
            "label": "Notify Secretary of New Member",
            "config": {
                "action": "Members.NotifySecretaryOfNewMember",
                "params": {
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": {
                "x": 1250,
                "y": 300
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "end-complete"
                }
            ]
        },
        "notify-secretary-minor": {
            "type": "action",
            "label": "Notify Secretary of New Minor",
            "config": {
                "action": "Members.NotifySecretaryOfNewMinorMember",
                "params": {
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": {
                "x": 950,
                "y": 100
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "end-complete"
                }
            ]
        },
        "end-complete": {
            "type": "end",
            "label": "Registration Complete",
            "config": {},
            "position": {
                "x": 1550,
                "y": 200
            },
            "outputs": []
        }
    },
    "startNode": "trigger-registration"
}
