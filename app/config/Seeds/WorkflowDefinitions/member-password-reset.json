{
    "nodes": {
        "trigger-password-reset": {
            "type": "trigger",
            "label": "Password Reset Requested",
            "config": {
                "event": "Members.PasswordResetRequested",
                "entityIdField": "memberId",
                "inputMapping": {
                    "memberId": "$.event.memberId",
                    "email": "$.event.email"
                }
            },
            "position": { "x": 50, "y": 200 },
            "outputs": [
                { "port": "next", "target": "send-password-reset" }
            ]
        },
        "send-password-reset": {
            "type": "action",
            "label": "Send Password Reset Email",
            "config": {
                "action": "Members.SendPasswordReset",
                "params": {
                    "memberId": "$.trigger.memberId",
                    "email": "$.trigger.email"
                }
            },
            "position": { "x": 350, "y": 200 },
            "outputs": [
                { "port": "next", "target": "end-complete" }
            ]
        },
        "end-complete": {
            "type": "end",
            "label": "Password Reset Sent",
            "config": {},
            "position": { "x": 650, "y": 200 },
            "outputs": []
        }
    },
    "startNode": "trigger-password-reset"
}
