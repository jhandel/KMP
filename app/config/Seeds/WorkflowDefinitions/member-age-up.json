{
    "nodes": {
        "trigger-age-up": {
            "type": "trigger",
            "label": "Age-Up Cron Triggered",
            "config": {
                "event": "Members.AgeUpTriggered",
                "entityIdField": "memberId",
                "inputMapping": {
                    "memberId": "$.event.memberId",
                    "previousAge": "$.event.previousAge",
                    "newAge": "$.event.newAge"
                }
            },
            "position": { "x": 50, "y": 200 },
            "outputs": [
                { "port": "next", "target": "age-up-member" }
            ]
        },
        "age-up-member": {
            "type": "action",
            "label": "Age Up Member",
            "config": {
                "action": "Members.AgeUpMember",
                "params": {
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": { "x": 350, "y": 200 },
            "outputs": [
                { "port": "next", "target": "check-now-adult" }
            ]
        },
        "check-now-adult": {
            "type": "condition",
            "label": "Is Now Adult?",
            "config": {
                "condition": "Members.IsAdult",
                "memberId": "$.trigger.memberId"
            },
            "position": { "x": 650, "y": 200 },
            "outputs": [
                { "port": "true", "target": "assign-member-role", "label": "Now Adult" },
                { "port": "false", "target": "sync-warrantable", "label": "Still Minor" }
            ]
        },
        "assign-member-role": {
            "type": "action",
            "label": "Upgrade to Member Role",
            "config": {
                "action": "Core.AssignRole",
                "params": {
                    "memberId": "$.trigger.memberId",
                    "role": "member",
                    "removeRole": "minor"
                }
            },
            "position": { "x": 950, "y": 100 },
            "outputs": [
                { "port": "next", "target": "sync-warrantable" }
            ]
        },
        "sync-warrantable": {
            "type": "action",
            "label": "Sync Warrantable Status",
            "config": {
                "action": "Members.SyncWarrantableStatus",
                "params": {
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": { "x": 1250, "y": 200 },
            "outputs": [
                { "port": "next", "target": "end-complete" }
            ]
        },
        "end-complete": {
            "type": "end",
            "label": "Age-Up Complete",
            "config": {},
            "position": { "x": 1550, "y": 200 },
            "outputs": []
        }
    },
    "startNode": "trigger-age-up"
}
