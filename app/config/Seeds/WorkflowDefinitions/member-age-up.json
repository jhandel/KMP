{
    "nodes": {
        "trigger-age-up": {
            "type": "trigger",
            "label": "Age-Up Cron Triggered",
            "config": {
                "event": "Members.AgeUpTriggered",
                "entityIdField": "memberId",
                "inputMapping": {
                    "memberId": "$.event.memberId"
                }
            },
            "position": { "x": 50, "y": 200 },
            "outputs": [
                { "port": "next", "target": "age-up-member" }
            ]
        },
        "age-up-member": {
            "type": "action",
            "label": "Age Up Member (status transition + clear parent)",
            "config": {
                "action": "Members.AgeUpMember",
                "params": {
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": { "x": 350, "y": 200 },
            "outputs": [
                { "port": "next", "target": "end-complete" }
            ]
        },
        "end-complete": {
            "type": "end",
            "label": "Age-Up Complete",
            "config": {},
            "position": { "x": 650, "y": 200 },
            "outputs": []
        }
    },
    "startNode": "trigger-age-up"
}
