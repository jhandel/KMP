{
    "nodes": {
        "trigger-renewal": {
            "type": "trigger",
            "label": "Authorization Renewal Requested",
            "config": {
                "event": "Activities.AuthorizationRequested",
                "entityIdField": "authorizationId",
                "inputMapping": {
                    "authorizationId": "$.event.authorizationId",
                    "memberId": "$.event.memberId",
                    "activityId": "$.event.activityId",
                    "activityName": "$.event.activityName",
                    "isRenewal": "$.event.isRenewal",
                    "requiredApprovals": "$.event.requiredApprovals",
                    "previousAuthorizationId": "$.event.previousAuthorizationId"
                }
            },
            "position": { "x": 50, "y": 200 },
            "outputs": [
                { "port": "next", "target": "check-renewal-eligible" }
            ]
        },
        "check-renewal-eligible": {
            "type": "condition",
            "label": "Is Renewal Eligible?",
            "config": {
                "condition": "Activities.IsRenewalEligible",
                "authorizationId": "$.trigger.previousAuthorizationId",
                "memberId": "$.trigger.memberId",
                "activityId": "$.trigger.activityId"
            },
            "position": { "x": 350, "y": 200 },
            "outputs": [
                { "port": "true", "target": "validate-renewal", "label": "Eligible" },
                { "port": "false", "target": "notify-ineligible", "label": "Not Eligible" }
            ]
        },
        "validate-renewal": {
            "type": "action",
            "label": "Validate Renewal Eligibility",
            "config": {
                "action": "Activities.ValidateRenewalEligibility",
                "params": {
                    "authorizationId": "$.trigger.authorizationId",
                    "previousAuthorizationId": "$.trigger.previousAuthorizationId",
                    "memberId": "$.trigger.memberId"
                }
            },
            "position": { "x": 650, "y": 100 },
            "outputs": [
                { "port": "next", "target": "approval-gate" }
            ]
        },
        "approval-gate": {
            "type": "approval",
            "label": "Renewal Approval Gate",
            "config": {
                "approverType": "dynamic",
                "approverConfig": {
                    "service": "Activities.AuthorizationApproverResolver",
                    "method": "getEligibleApproverIds",
                    "activity_id": "$.trigger.activityId"
                },
                "requiredCount": "$.trigger.requiredApprovals",
                "serialPickNext": true,
                "allowParallel": false,
                "allowComments": true,
                "deadline": "30d"
            },
            "position": { "x": 950, "y": 100 },
            "outputs": [
                { "port": "approved", "target": "activate-authorization" },
                { "port": "rejected", "target": "handle-denial" }
            ]
        },
        "activate-authorization": {
            "type": "action",
            "label": "Activate Renewed Authorization",
            "config": {
                "action": "Activities.ActivateAuthorization",
                "params": {
                    "authorizationId": "$.trigger.authorizationId",
                    "approverId": "$.resumeData.approverId",
                    "isRenewal": true
                }
            },
            "position": { "x": 1250, "y": 50 },
            "outputs": [
                { "port": "next", "target": "retract-previous" }
            ]
        },
        "retract-previous": {
            "type": "action",
            "label": "Retract Previous Authorization",
            "config": {
                "action": "Activities.RetractAuthorization",
                "params": {
                    "authorizationId": "$.trigger.previousAuthorizationId",
                    "reason": "Renewed by new authorization"
                }
            },
            "position": { "x": 1550, "y": 50 },
            "outputs": [
                { "port": "next", "target": "notify-approved" }
            ]
        },
        "notify-approved": {
            "type": "action",
            "label": "Notify Requester (Renewed)",
            "config": {
                "action": "Activities.NotifyRequester",
                "params": {
                    "activityId": "$.trigger.activityId",
                    "requesterId": "$.trigger.memberId",
                    "approverId": "$.resumeData.approverId",
                    "status": "approved"
                }
            },
            "position": { "x": 1850, "y": 50 },
            "outputs": [
                { "port": "next", "target": "end-renewed" }
            ]
        },
        "handle-denial": {
            "type": "action",
            "label": "Handle Renewal Denial",
            "config": {
                "action": "Activities.HandleDenial",
                "params": {
                    "authorizationId": "$.trigger.authorizationId",
                    "approverId": "$.resumeData.approverId",
                    "denyReason": "$.resumeData.comment"
                }
            },
            "position": { "x": 1250, "y": 200 },
            "outputs": [
                { "port": "next", "target": "notify-denied" }
            ]
        },
        "notify-denied": {
            "type": "action",
            "label": "Notify Requester (Denied)",
            "config": {
                "action": "Activities.NotifyRequester",
                "params": {
                    "activityId": "$.trigger.activityId",
                    "requesterId": "$.trigger.memberId",
                    "approverId": "$.resumeData.approverId",
                    "status": "denied"
                }
            },
            "position": { "x": 1550, "y": 200 },
            "outputs": [
                { "port": "next", "target": "end-denied" }
            ]
        },
        "notify-ineligible": {
            "type": "action",
            "label": "Notify Requester (Ineligible)",
            "config": {
                "action": "Activities.NotifyRequester",
                "params": {
                    "activityId": "$.trigger.activityId",
                    "requesterId": "$.trigger.memberId",
                    "status": "ineligible"
                }
            },
            "position": { "x": 650, "y": 350 },
            "outputs": [
                { "port": "next", "target": "end-ineligible" }
            ]
        },
        "end-renewed": {
            "type": "end",
            "label": "Renewal Complete",
            "config": {},
            "position": { "x": 2150, "y": 50 },
            "outputs": []
        },
        "end-denied": {
            "type": "end",
            "label": "Renewal Denied",
            "config": {},
            "position": { "x": 1850, "y": 200 },
            "outputs": []
        },
        "end-ineligible": {
            "type": "end",
            "label": "Not Eligible for Renewal",
            "config": {},
            "position": { "x": 950, "y": 350 },
            "outputs": []
        }
    },
    "startNode": "trigger-renewal"
}
