{
    "nodes": {
        "trigger": {
            "type": "trigger",
            "label": "Create Recommendation Requested",
            "config": {
                "event": "Awards.RecommendationCreateRequested"
            },
            "position": {
                "x": 50,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "create-recommendation"
                }
            ]
        },
        "create-recommendation": {
            "type": "action",
            "label": "Create Recommendation",
            "config": {
                "action": "Awards.CreateRecommendation",
                "params": {
                    "data": "$.trigger.data",
                    "requesterContext": "$.trigger.requesterContext",
                    "submissionMode": "$.trigger.submissionMode"
                }
            },
            "position": {
                "x": 350,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "create-succeeded"
                }
            ]
        },
        "create-succeeded": {
            "type": "condition",
            "label": "Create Succeeded?",
            "config": {
                "condition": "Core.FieldEquals",
                "field": "$.nodes.create-recommendation.result.success",
                "value": true
            },
            "position": {
                "x": 650,
                "y": 250
            },
            "outputs": [
                {
                    "port": "true",
                    "target": "notify-crown",
                    "label": "Created"
                },
                {
                    "port": "false",
                    "target": "end-failed",
                    "label": "Failed"
                }
            ]
        },
        "notify-crown": {
            "type": "action",
            "label": "Email Crown",
            "config": {
                "action": "Core.SendEmail",
                "params": {
                    "to": "crown@ansteorra.org",
                    "template": "award-recommendation-submitted",
                    "vars": {
                        "memberScaName": "$.nodes.create-recommendation.result.data.eventPayload.memberScaName",
                        "awardName": "$.nodes.create-recommendation.result.data.eventPayload.awardName",
                        "reason": "$.nodes.create-recommendation.result.data.eventPayload.reason",
                        "contactEmail": "$.nodes.create-recommendation.result.data.eventPayload.contactEmail"
                    }
                }
            },
            "position": {
                "x": 950,
                "y": 250
            },
            "outputs": [
                {
                    "port": "next",
                    "target": "end-created"
                }
            ]
        },
        "end-created": {
            "type": "end",
            "label": "Create Complete",
            "config": {
                "result": "$.nodes.create-recommendation.result"
            },
            "position": {
                "x": 1250,
                "y": 250
            },
            "outputs": []
        },
        "end-failed": {
            "type": "end",
            "label": "Create Failed",
            "config": {
                "result": "$.nodes.create-recommendation.result"
            },
            "position": {
                "x": 950,
                "y": 400
            },
            "outputs": []
        }
    },
    "startNode": "trigger"
}
