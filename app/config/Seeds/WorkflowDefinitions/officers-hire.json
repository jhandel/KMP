{
    "nodes": {
        "trigger-hire": {
            "type": "trigger",
            "label": "Officer Hire Requested",
            "config": {
                "event": "Officers.HireRequested",
                "entityIdField": "officerId",
                "inputMapping": {
                    "memberId": "$.event.memberId",
                    "officeId": "$.event.officeId",
                    "branchId": "$.event.branchId",
                    "startOn": "$.event.startOn",
                    "expiresOn": "$.event.expiresOn",
                    "deputyToId": "$.event.deputyToId",
                    "officerId": "$.event.officerId",
                    "emailAddress": "$.event.emailAddress",
                    "deputyDescription": "$.event.deputyDescription"
                }
            },
            "position": { "x": 50, "y": 250 },
            "outputs": [
                { "port": "next", "target": "check-only-one-per-branch" }
            ]
        },
        "check-only-one-per-branch": {
            "type": "condition",
            "label": "Is Only One Per Branch?",
            "config": {
                "condition": "Officers.IsOnlyOnePerBranch",
                "officeId": "$.trigger.officeId",
                "branchId": "$.trigger.branchId"
            },
            "position": { "x": 350, "y": 250 },
            "outputs": [
                { "port": "true", "target": "check-has-conflict", "label": "Yes" },
                { "port": "false", "target": "check-requires-warrant", "label": "No" }
            ]
        },
        "check-has-conflict": {
            "type": "condition",
            "label": "Has Conflicting Officer?",
            "config": {
                "condition": "Officers.HasConflictingOfficer",
                "officeId": "$.trigger.officeId",
                "branchId": "$.trigger.branchId",
                "memberId": "$.trigger.memberId"
            },
            "position": { "x": 650, "y": 150 },
            "outputs": [
                { "port": "true", "target": "release-conflicting", "label": "Conflict Found" },
                { "port": "false", "target": "check-requires-warrant", "label": "No Conflict" }
            ]
        },
        "release-conflicting": {
            "type": "action",
            "label": "Release Conflicting Officers",
            "config": {
                "action": "Officers.ReleaseConflictingOfficers",
                "params": {
                    "officeId": "$.trigger.officeId",
                    "branchId": "$.trigger.branchId",
                    "newMemberId": "$.trigger.memberId"
                }
            },
            "position": { "x": 950, "y": 50 },
            "outputs": [
                { "port": "next", "target": "check-requires-warrant" }
            ]
        },
        "check-requires-warrant": {
            "type": "condition",
            "label": "Office Requires Warrant?",
            "config": {
                "condition": "Officers.OfficeRequiresWarrant",
                "officeId": "$.trigger.officeId"
            },
            "position": { "x": 950, "y": 250 },
            "outputs": [
                { "port": "true", "target": "check-warrantable", "label": "Yes" },
                { "port": "false", "target": "create-officer", "label": "No" }
            ]
        },
        "check-warrantable": {
            "type": "condition",
            "label": "Member Warrantable?",
            "config": {
                "condition": "Officers.IsMemberWarrantable",
                "memberId": "$.trigger.memberId"
            },
            "position": { "x": 1250, "y": 150 },
            "outputs": [
                { "port": "true", "target": "get-warrant-period", "label": "Yes" },
                { "port": "false", "target": "end-rejected", "label": "No" }
            ]
        },
        "get-warrant-period": {
            "type": "action",
            "label": "Get Warrant Period",
            "config": {
                "action": "Warrants.GetWarrantPeriod",
                "params": {
                    "officeId": "$.trigger.officeId",
                    "branchId": "$.trigger.branchId"
                }
            },
            "position": { "x": 1550, "y": 50 },
            "outputs": [
                { "port": "next", "target": "create-direct-warrant" }
            ]
        },
        "create-direct-warrant": {
            "type": "action",
            "label": "Create Direct Warrant",
            "config": {
                "action": "Warrants.CreateDirectWarrant",
                "params": {
                    "memberId": "$.trigger.memberId",
                    "officeId": "$.trigger.officeId",
                    "branchId": "$.trigger.branchId",
                    "startOn": "$.nodes.get-warrant-period.result.startOn",
                    "expiresOn": "$.nodes.get-warrant-period.result.expiresOn"
                }
            },
            "position": { "x": 1850, "y": 50 },
            "outputs": [
                { "port": "next", "target": "create-officer" }
            ]
        },
        "create-officer": {
            "type": "action",
            "label": "Create Officer Record",
            "config": {
                "action": "Officers.CreateOfficerRecord",
                "params": {
                    "memberId": "$.trigger.memberId",
                    "officeId": "$.trigger.officeId",
                    "branchId": "$.trigger.branchId",
                    "startOn": "$.trigger.startOn",
                    "expiresOn": "$.trigger.expiresOn",
                    "emailAddress": "$.trigger.emailAddress",
                    "deputyDescription": "$.trigger.deputyDescription"
                }
            },
            "position": { "x": 1550, "y": 350 },
            "outputs": [
                { "port": "next", "target": "calculate-reporting" }
            ]
        },
        "calculate-reporting": {
            "type": "action",
            "label": "Calculate Reporting Fields",
            "config": {
                "action": "Officers.CalculateReportingFields",
                "params": {
                    "officerId": "$.nodes.create-officer.result.officerId"
                }
            },
            "position": { "x": 1850, "y": 350 },
            "outputs": [
                { "port": "next", "target": "recalculate-office" }
            ]
        },
        "recalculate-office": {
            "type": "action",
            "label": "Recalculate Officers for Office",
            "config": {
                "action": "Officers.RecalculateOfficersForOffice",
                "params": {
                    "officeId": "$.trigger.officeId",
                    "branchId": "$.trigger.branchId"
                }
            },
            "position": { "x": 2150, "y": 350 },
            "outputs": [
                { "port": "next", "target": "send-hire-notification" }
            ]
        },
        "send-hire-notification": {
            "type": "action",
            "label": "Send Hire Notification",
            "config": {
                "action": "Officers.SendHireNotification",
                "params": {
                    "officerId": "$.nodes.create-officer.result.officerId"
                }
            },
            "position": { "x": 2450, "y": 350 },
            "outputs": [
                { "port": "next", "target": "end-complete" }
            ]
        },
        "end-complete": {
            "type": "end",
            "label": "Hire Complete",
            "config": {},
            "position": { "x": 2750, "y": 350 },
            "outputs": []
        },
        "end-rejected": {
            "type": "end",
            "label": "Rejected — Not Warrantable",
            "config": {},
            "position": { "x": 1550, "y": 150 },
            "outputs": []
        }
    },
    "startNode": "trigger-hire"
}
