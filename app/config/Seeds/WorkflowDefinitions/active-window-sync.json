{
    "nodes": {
        "trigger-sync": {
            "type": "trigger",
            "label": "Active Window Sync Triggered",
            "config": {
                "event": "ActiveWindow.SyncTriggered",
                "entityIdField": null,
                "inputMapping": {
                    "triggeredAt": "$.event.triggeredAt"
                }
            },
            "position": { "x": 50, "y": 200 },
            "outputs": [
                { "port": "next", "target": "sync-statuses" }
            ]
        },
        "sync-statuses": {
            "type": "action",
            "label": "Sync Active Window Statuses",
            "config": {
                "action": "Core.SyncActiveWindowStatuses",
                "params": {
                    "triggeredAt": "$.trigger.triggeredAt"
                }
            },
            "position": { "x": 350, "y": 200 },
            "outputs": [
                { "port": "next", "target": "end-complete" }
            ]
        },
        "end-complete": {
            "type": "end",
            "label": "Sync Complete",
            "config": {},
            "position": { "x": 650, "y": 200 },
            "outputs": []
        }
    },
    "startNode": "trigger-sync"
}
