# Legacy/local compatibility values. New tenant-aware code uses PLATFORM_DB_*
# for global tenant metadata and TENANT_DB_* for the default/template tenant.
export MYSQL_HOST='localhost'
export MYSQL_PORT='3306'
export MYSQL_USERNAME='YOUR_USERNAME'
export MYSQL_PASSWORD='YOUR_PASSWORD'
export MYSQL_DB_NAME='YOUR_TENANT_DB_NAME'

# Platform registry datastore: global tenant metadata only. Do not point this at
# a tenant application database.
export PLATFORM_DB_HOST='YOUR_PLATFORM_DB_HOST'
export PLATFORM_DB_PORT='3306'
export PLATFORM_DB_USERNAME='YOUR_PLATFORM_DB_USERNAME'
export PLATFORM_DB_PASSWORD='YOUR_PLATFORM_DB_PASSWORD'
export PLATFORM_DB_DATABASE='kmp_platform'
export PLATFORM_DATABASE_URL=''
# Required when using platform-managed encrypted secrets (`managed:*`).
# Use a high-entropy value of at least 32 characters and keep it stable.
export PLATFORM_SECRET_KEY=''
export PLATFORM_SECRET_KEY_VERSION='v1'

# Optional default/template tenant connection for local dev and tenant:create defaults.
# Production tenant-specific DB names/hosts/credentials live in the platform
# tenant_database_configs table, usually with per-tenant secret references such as
# env:ANSTEORRA_DB_PASSWORD or an external vault key.
export TENANT_DB_HOST=''
export TENANT_DB_PORT=''
export TENANT_DB_USERNAME=''
export TENANT_DB_PASSWORD=''
export TENANT_DB_DATABASE=''
export TENANT_DATABASE_URL=''

# Tenant-specific email/storage settings also belong in platform tenant_service_configs,
# not shared global .env values. Use tenant-specific secret references there, e.g.
# env:ANSTEORRA_SMTP_PASSWORD or env:ANSTEORRA_AZURE_STORAGE_CONNECTION_STRING.
# Local dev may set a referenced tenant secret, e.g. LOCALDEV_SMTP_PASSWORD.
export LOCALDEV_SMTP_PASSWORD=''

# Platform admin console. Use a dedicated host that is not a tenant alias.
export PLATFORM_ADMIN_HOSTS='admin.localhost'
# Local/dev convenience only. Leave empty in production to keep tenant-host
# platform-admin requests as 404 responses.
export PLATFORM_ADMIN_REDIRECT_FROM_HOSTS='localhost,127.0.0.1'
# Optional local/dev seed admin values. If PLATFORM_ADMIN_SEED_PASSWORD is empty,
# platform_admin:seed generates and prints a random first-login password.
export PLATFORM_ADMIN_SEED_EMAIL='platform-admin@localhost.test'
export PLATFORM_ADMIN_SEED_DISPLAY_NAME='Local Platform Admin'
export PLATFORM_ADMIN_SEED_PASSWORD=''
# Platform email is separate from tenant email and is configured in
# platform_service_configs for password reset, recovery, and security notices.
export PLATFORM_SMTP_PASSWORD=''

export EMAIL_DRIVER='smtp'
export EMAIL_FROM='noreply@localhost'
export EMAIL_SMTP_HOST='YOUR_SMTP_HOST'
export EMAIL_SMTP_PORT='1025'
export EMAIL_SMTP_USERNAME='YOUR_SMTP_USERNAME'
export EMAIL_SMTP_PASSWORD='YOUR_SMTP_PASSWORD'
export AZURE_COMMUNICATION_CONNECTION_STRING='endpoint=https://xxx.communication.azure.com/;accesskey=BASE64KEY'
export EMAIL_API_KEY='YOUR_SENDGRID_OR_RESEND_API_KEY'
export PATH_WKHTML='/usr/bin/wkhtmltopdf'
export AZURE_STORAGE_CONNECTION_STRING='SET THIS IF YOU ARE USING AZURE STORAGE'
export AWS_S3_BUCKET='SET THIS IF YOU ARE USING S3 STORAGE'
export AWS_DEFAULT_REGION='us-east-1'
export AWS_ACCESS_KEY_ID=''
export AWS_SECRET_ACCESS_KEY=''
export AWS_SESSION_TOKEN=''
export AWS_S3_PREFIX=''
export AWS_S3_ENDPOINT=''
export AWS_S3_USE_PATH_STYLE_ENDPOINT='false'
export PERF_REQUEST_LOG_ENABLED='false'
export PERF_SLOW_REQUEST_MS='750'
export PERF_LOG_ALL_REQUESTS='false'
export LOG_PERFORMANCE_URL=''
